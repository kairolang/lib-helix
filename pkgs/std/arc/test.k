test "lists" {
    define p_list! {
        print(li);
    };

    var li: list<int> = [1, 2, 3, 4, 5, 6];
    p_list!

    print(sizeof!(li));

    li.append(1);
    p_list!

    li += 2;

    var li2 = [1, 2, 3];
    li = li + li2;

    p_list!
}